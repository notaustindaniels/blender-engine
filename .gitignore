# ── Security: never commit secrets or private/large artifacts (SPEC §7, PRD §4) ──
# Vaulted add-on artifacts: large, private, redistribution-guarded (PRD guardrail #3)
vault/
# Harvested asset payloads (A-lane CC assets, D-004/R25): large binaries, attribution
# tracked in the registry/asset report, not the blobs themselves
vault_assets/
# Acquisition dropzone: large binary checkouts (.blend etc.) staged for probing, not deliverables
inputs/dropzone/
# SQLite read-index: disposable, rebuilt from JSON manifests (SPEC §4.5)
*.db
*.db-journal
*.db-wal
# Any session/cookie material (marketplace creds, etc.)
*session*
# Env files — secrets (GH_TOKEN, marketplace creds) come from env injection only (SPEC §6.5)
.env
.env.*
!.env.example

# Archon runtime artifacts — never commit (repo-init.md)
.archon/state/
.archon/.env

# Progress server noise
progress/server.log
progress/.server.pid

# Python / tooling noise
__pycache__/
*.pyc
.pytest_cache/
.venv/
node_modules/
.DS_Store

# Sandbox scratch
sandbox/scratch/

# Playwright MCP runtime logs (browser snapshots from seed-anchor verification) — not deliverables
.playwright-mcp/

# Claude Code machine-local settings (not a deliverable)
.claude/settings.local.json
.agent-lock

# D-008 named deliverable — explicitly tracked (vetted no-secret campaign tracker)
!NEXT-SESSION.md

# generated served mirror of THE LIST (canonical is reports/catalog/index.html; regenerated by catalog_page.py)
progress/catalog.html
progress/server.log
progress/.server.pid
